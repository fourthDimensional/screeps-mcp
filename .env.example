# Screeps MCP Server environment variables

# Authentication: pick one method

# Option 1: Token authentication (recommended)
# Generate a token at: https://screeps.com/a/#!/account/auth-tokens
SCREEPS_TOKEN=your_token_here

# Option 2: Email and password
# SCREEPS_EMAIL=your@email.com
# SCREEPS_PASSWORD=your_password

# Server configuration
SCREEPS_SERVER=http://localhost:21025
SCREEPS_BRANCH=default
