# Screeps MCP Server environment variables

# Authentication: pick one method

# Option 1: Token authentication (recommended)
# Generate a token at: https://screeps.com/a/#!/account/auth-tokens
SCREEPS_TOKEN=your_token_here

# Option 2: Email and password
# SCREEPS_EMAIL=your@email.com
# SCREEPS_PASSWORD=your_password

# Server configuration
SCREEPS_SERVER=http://localhost:21025
SCREEPS_BRANCH=default
SCREEPS_SHARD=shard0
# Approximate live shard tick duration used for bounded probe waits.
SCREEPS_TICK_DURATION_MS=5000

# Harness safety and local state
# development, staging, or production. Production mutations require explicit approval.
SCREEPS_ENVIRONMENT=development
# Optional comma-separated operation overrides, e.g. "code_upload,branch_activation"
SCREEPS_APPROVED_OPERATIONS=
SCREEPS_AUDIT_PATH=.screeps-mcp/audit.jsonl
SCREEPS_DEPLOYMENTS_PATH=.screeps-mcp/deployments.json
SCREEPS_METRICS_PATH=.screeps-mcp/metrics.json
# Optional path to the generated docs index. Defaults to ./data/screeps_docs.db
# SCREEPS_DOCS_DB=./data/screeps_docs.db
# Root directory from which file-based module tools may read. Defaults to the MCP process cwd.
# SCREEPS_SOURCE_ROOT=/absolute/path/to/your/bot
